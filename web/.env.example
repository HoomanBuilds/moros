# Public Supabase project URL, from Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key, safe for the browser, from Project Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key, never expose to the browser, from Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL used in wallet sign-in challenges
NEXT_PUBLIC_SITE_URL=https://moros-six.vercel.app

# Use testnet during beta. Set mainnet only with deployed mainnet contract IDs.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SEED_MARKET_ID=
NEXT_PUBLIC_SEED_POOL_ID=

# Deployed quorum price and optimistic bonded event resolvers for this network
NEXT_PUBLIC_FREE_PRICE_RESOLVER_ID=CAIHZHCNKHLCXGWOTH7T2L4S5YDNNGO6Q6MSDQ7HQ3A4IORN4NE6ZF5B
NEXT_PUBLIC_PYTH_PRO_PRICE_RESOLVER_ID=
NEXT_PUBLIC_EVENT_RESOLVER_ID=CBOZK2JSSAOPXJWBSB6JZF5KLPMRQ52JCF4PADI7QUHQ3WS6KBKKBXW5

# Keep free for the testnet beta. pyth_pro remains an optional future switch.
NEXT_PUBLIC_ORACLE_MODE=free

# Public Stellar address receiving the 2% fee on winning profit
NEXT_PUBLIC_PLATFORM_TREASURY=GANVOL5URROHRSW634VIMFQQH7YTTFZPUMLT4X5QGQO6P76YBFDLN7U5
